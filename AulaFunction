--Exercício 02 da aula prática 30/04/2026
select * from paciente;
create or replace function FN_verCodigo(pCodPaciente paciente .codpaciente%type) return varchar2 as
v_data date;
v_conta number;
begin
select datanasc into v_data from paciente where codpaciente = pCodPaciente;
v_conta := (sysdate - v_data)/365.25;
if v_conta > 65 then
return 'Idoso';
else
return 'Não idoso';
end if;
end;
select codpaciente, datanasc, FN_verCodigo(codPaciente)
from paciente;
